NODE_ENV=development
PORT=3001
APP_URL=http://localhost:5173
API_URL=http://localhost:3001
VITE_API_BASE_URL=
DATABASE_PATH=./server/data/dinkcard.db
UPLOAD_DIR=./uploads
TERMS_VERSION=v1.2

# Create these yourself. Use long random values and never expose them in the frontend.
JWT_SECRET=
COOKIE_SECRET=
CARD_DATA_ENCRYPTION_KEY=

# Change before production.
SUPERADMIN_USERNAME=NebiyuEla
SUPERADMIN_PASSWORD=
SUPERADMIN_EMAIL=

# Chapa: copy public/secret keys from your Chapa dashboard.
# CHAPA_WEBHOOK_SECRET is the random secret hash you set when creating the Chapa webhook.
CHAPA_MODE=test
CHAPA_PUBLIC_KEY=
VITE_CHAPA_PUBLIC_KEY=
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=
CHAPA_CALLBACK_URL=http://localhost:3001/api/payments/chapa/callback
CHAPA_RETURN_URL=http://localhost:5173/add-money

# Bitnob: copy client credentials from your Bitnob dashboard.
# BITNOB_WEBHOOK_SECRET is the signing secret used to verify Bitnob webhook payloads.
BITNOB_CLIENT_ID=
BITNOB_CLIENT_SECRET=
BITNOB_BASE_URL=https://api.bitnob.com
BITNOB_WEBHOOK_SECRET=
BITNOB_WEBHOOK_URL=http://localhost:3001/api/webhooks/bitnob

# Production example for Render full-stack deployment on dinkcard.et:
# NODE_ENV=production
# APP_URL=https://dinkcard.et
# API_URL=https://dinkcard.et
# VITE_API_BASE_URL=
# DATABASE_PATH=/var/data/dinkcard.db
# UPLOAD_DIR=/var/data/uploads
# CHAPA_CALLBACK_URL=https://dinkcard.et/api/payments/chapa/callback
# CHAPA_RETURN_URL=https://dinkcard.et/add-money
# BITNOB_WEBHOOK_URL=https://dinkcard.et/api/webhooks/bitnob
